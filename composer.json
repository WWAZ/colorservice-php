{
    "name": "wwaz/colorservice-php",
    "description": "Bridge screen RGB and print CMYK using ICC profiles — with perception preview, color names, and schemes.",
    "type": "library",
    "keywords": [
        "color",
        "icc",
        "cmyk",
        "rgb",
        "color-profile",
        "color-service",
        "color-schemes"
    ],
    "homepage": "https://github.com/WWAZ/colorservice-php",
    "license": "MIT",
    "authors": [
        {
            "name": "WWAZ"
        }
    ],
    "support": {
        "issues": "https://github.com/WWAZ/colorservice-php/issues",
        "source": "https://github.com/WWAZ/colorservice-php"
    },
    "require": {
        "php": "^8.2",
        "wwaz/colorconvert-php": "^1.3",
        "wwaz/colorprofile-php": "^0.1",
        "wwaz/colormodel-php": "^1.0",
        "wwaz/colorname-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "wwaz\\ColorService\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "wwaz\\ColorService\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
